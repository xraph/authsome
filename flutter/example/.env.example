# AuthSome Flutter example — environment template.
# Copy to .env and edit for your local dev backend.

# Base URL of the AuthSome HTTP API.
# Examples:
#   http://localhost:8080                          # standalone authsome binary
#   http://192.168.4.153:7903/identity/authsome    # TwinOS-style studio gateway
AUTHSOME_BASE_URL=http://localhost:8080

# Publishable key (pk_live_* / pk_test_* / pk_stg_*). Leave empty to skip
# client-config auto-discovery.
AUTHSOME_PUBLISHABLE_KEY=
