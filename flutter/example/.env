# AuthSome Flutter example — local dev environment.
#
# Loaded by flutter_dotenv as a bundled asset on startup (see main.dart).
# Edit per-machine. Production builds should override via --dart-define
# instead so secrets don't ship in the bundle.

# Base URL of the AuthSome HTTP API. For TwinOS-style deployments this is
# the studio gateway with /identity/authsome appended.
AUTHSOME_BASE_URL=http://192.168.4.153:7903/identity/authsome

# Publishable key — pk_live_* / pk_test_* / pk_stg_*. When set, the SDK
# fetches /v1/client-config on startup to auto-discover enabled methods.
AUTHSOME_PUBLISHABLE_KEY=pk_live_504d477ecbafc3954de843155bed1b2d57d2288270db25a2ccedd5a9161a65b4
