package components

import "github.com/xraph/forgeui/components/separator"

// PluginSections renders a list of plugin-contributed sections separated by
// ForgeUI separators. If sections is empty, nothing is rendered.
templ PluginSections(sections []templ.Component) {
	if len(sections) > 0 {
		<div class="space-y-8">
			for i, section := range sections {
				if i > 0 {
					@separator.Separator()
				}
				@section
			}
		</div>
	}
}
