package components

// PluginSections renders a list of plugin-contributed sections with consistent
// vertical spacing. If sections is empty, nothing is rendered.
templ PluginSections(sections []templ.Component) {
	if len(sections) > 0 {
		<div class="space-y-10">
			for _, section := range sections {
				@section
			}
		</div>
	}
}
